{
  "name": "prek-action",
  "version": "1.0.0",
  "private": true,
  "description": "GitHub Action to install and run prek",
  "type": "module",
  "scripts": {
    "build": "tsc --noEmit",
    "bundle": "node scripts/build-dist.mjs",
    "test": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js",
    "update-known-versions": "node scripts/update-known-versions.mjs"
  },
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "@actions/cache": "^6.0.0",
    "@actions/core": "^3.0.0",
    "@actions/exec": "^3.0.0",
    "@actions/glob": "^0.6.0",
    "@actions/http-client": "^4.0.0",
    "@actions/io": "^3.0.0",
    "@actions/tool-cache": "^4.0.0",
    "semver": "^7.7.4",
    "string-argv": "^0.3.2"
  },
  "devDependencies": {
    "@jest/globals": "^30.2.0",
    "@types/node": "^24.0.0",
    "@types/semver": "^7.7.1",
    "esbuild": "^0.25.10",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.1",
    "typescript": "^5.9.3"
  }
}
